# Database (Vercel Postgres / Neon)
POSTGRES_URL=your_vercel_postgres_url

# Anthropic API (report generation)
ANTHROPIC_API_KEY=your_anthropic_api_key

# App URL (used for invite links)
APP_URL=https://your-app.vercel.app

# Email (SMTP — required for sending invite emails)
# If not configured, invites still work via clipboard link sharing
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_FROM=noreply@providentstrat.com
